    "@vue/test-utils": "^2.4.10",
    "happy-dom": "^20.9.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.5",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.1.10"
  }
