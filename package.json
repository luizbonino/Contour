{
  "name": "contour",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Contour — visual SHACL schema editor for the FAIR Data Point ecosystem",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
